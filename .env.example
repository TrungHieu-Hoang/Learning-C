# === REQUIRED ===

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/clearn?schema=public"

# NextAuth requires a secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# === OPTIONAL (at least one OAuth provider needed for sign-in) ===

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth — https://github.com/settings/developers
GITHUB_ID=""
GITHUB_SECRET=""
